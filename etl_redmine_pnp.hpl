    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>var versao_projeto = upper(versao_projeto);

if(versao_projeto.match("\\[(\\d+\\.X\\.X)\\]")){
  var etapaAtual = "Planejamento";
} else if(versao_projeto.match("\\[(\\d+\\.\\d+\\.X)\\]")){
  var etapaAtual = "Desenvolvimento";
} else{
 var etapaAtual = "Implantação";
}
var matchSprints = versao_projeto.match("\\[(\\d+)\\..*\\]")

if(matchSprints){
  var numeroSprints = matchSprints[1];
}
</jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
